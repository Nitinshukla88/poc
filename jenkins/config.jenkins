apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://kubernetes.docker.internal:6443
  name: docker-desktop
- cluster:
    certificate-authority-data: 
    server: https://self-healing-cluster-control-plane:6443

  name: kind-self-healing-cluster
contexts:
- context:
    cluster: docker-desktop
    user: docker-desktop
  name: docker-desktop
- context:
    cluster: kind-self-healing-cluster
    user: kind-self-healing-cluster
  name: kind-self-healing-cluster
current-context: kind-self-healing-cluster
kind: Config
users:
- name: docker-desktop
  user:
    client-certificate-data: 
    client-key-data: 
- name: kind-self-healing-cluster
  user:
    client-certificate-data: 
    client-key-data: 
